{
  "name": "@anwarhossainsr/sendkit",
  "version": "0.1.0",
  "description": "SendKit CLI - A command-line interface for MCP tools",
  "bin": {
    "sendkit": "./dist/index.js"
  },
  "files": [
    "dist"
  ],
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsdown",
    "pack:dry": "bun run build && npm pack --dry-run",
    "prepublishOnly": "bun run build"
  },
  "dependencies": {
    "@anwarhossainsr/sendkit-core": "workspace:*",
    "commander": "^15.0.0",
    "zod": "^4.4.3"
  }
}
