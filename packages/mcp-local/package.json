{
  "name": "@anwarhossainsr/sendkit-mcp-local",
  "version": "0.0.0",
  "description": "SendKit local MCP server (stdio transport)",
  "files": [
    "dist"
  ],
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsdown",
    "pack:dry": "bun run build && npm pack --dry-run",
    "prepublishOnly": "bun run build"
  },
  "dependencies": {
    "@anwarhossainsr/sendkit-core": "workspace:*",
    "@modelcontextprotocol/sdk": "1.29.0",
    "zod": "^3.25.76"
  }
}
